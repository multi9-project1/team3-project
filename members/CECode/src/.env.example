# =your_api_key_here
# 제주 여행 추천 시스템 - 환경변수 설정
# =your_api_key_here
# 
# ⚠️ 보안 주의사항:
# - 이 파일은 절대 Git에 커밋하지 마세요!
# - .gitignore에 .env를 추가하세요
# - API 키는 외부에 노출되지 않도록 주의하세요
#
# =your_api_key_here

# 카카오 REST API 키
# - 발급: https://developers.kakao.com
# - 용도: 장소 검색, 주소 검색, 네비게이션 경로 계산
KAKAO_API_KEY=your_api_key_here

# OpenAI API 키
# - 발급: https://platform.openai.com/api-keys
# - 용도: AI 기반 여행 코스 최적화
# - 비용: 한 번 추천당 약 10~40원
OPENAI_API_KEY=your_api_key_here

# OpenAI 모델 설정
# - gpt-4o-mini: 빠르고 저렴 (추천)
# - gpt-4o: 더 정확하지만 비쌈
OPENAI_MODEL=your_api_key_here
