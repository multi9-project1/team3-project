# .env.example  |  복사 후 .env 로 이름 변경하여 사용
# 실제 API 키는 앱 내 사이드바에서 직접 입력하거나 이 파일에 저장 가능

# 카카오 REST API 키 (https://developers.kakao.com)
KAKAO_API_KEY=여기에_카카오_REST_API_키_입력

# OpenAI API 키 (https://platform.openai.com/api-keys)
# 선택사항 - 없으면 기본 추천만 동작
OPENAI_API_KEY=여기에_OpenAI_API_키_입력

# OpenAI 모델 (기본: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
