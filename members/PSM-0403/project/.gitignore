__pycache__/
*.py[cod]
*$py.class
*.so

# Streamlit 캐시
.streamlit/

# 가상환경
venv/
env/
ENV/
.venv

# IDE 설정
.vscode/
.idea/
*.swp
*.swo
*~

# OS 파일
.DS_Store
Thumbs.db

# 로그 파일
*.log

# 임시 파일
*.tmp
*.temp
